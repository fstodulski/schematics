{
  "$schema": "http://json-schema.org/schema",
  "id": "SchematicsNgxsFacade",
  "title": "Ngxs Facade Options Schema",
  "type": "object",
  "properties": {
    "name": {
      "description": "The name of the facade.",
      "type": "string",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "x-prompt": "What name would you like to use for the Facade?"
    },
    "path": {
      "type": "string",
      "format": "path",
      "description": "The path to create the facade."
    },
    "sourceRoot": {
      "type": "string",
      "format": "path",
      "description": "The source root path"
    }
  },
  "required": [
    "name"
  ]
}
