{
  "$schema": "http://json-schema.org/schema",
  "id": "SchematicsNgxsSelectors",
  "title": "Ngxs Selectors Options Schema",
  "type": "object",
  "properties": {
    "name": {
      "description": "The name of the selectors.",
      "type": "string",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "x-prompt": "What name would you like to use for the Selectors?"
    },
    "path": {
      "type": "string",
      "format": "path",
      "description": "The path to create the selectors."
    },
    "sourceRoot": {
      "type": "string",
      "format": "path",
      "description": "The source root path"
    }
  },
  "required": [
    "name"
  ]
}
